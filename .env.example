# Shared
NODE_ENV=development
WORKSPACE_ID=workspace_demo
WORKSPACE_SLUG=wickedhost
WORKSPACE_NAME=WickedHost
ADMIN_TOKEN=change-me-before-production
WEB_SESSION_SECRET=change-me-too
SECRETS_ENCRYPTION_KEY=change-me-secret-key
VECTOR_BACKEND=qdrant
PGVECTOR_TABLE=pgvector_chunk_embeddings
API_PORT=4000
WEB_PORT=3000
BOT_HEALTH_PORT=4100
WORKER_HEALTH_PORT=4200
PUBLIC_API_BASE_URL=http://api:4000
WEB_API_BASE_URL=http://api:4000

# Postgres
POSTGRES_DB=wickedhostbotai
POSTGRES_USER=wickedhost
POSTGRES_PASSWORD=wickedhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://wickedhost:wickedhost@postgres:5432/wickedhostbotai

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_PORT=6334
QDRANT_COLLECTION=wickedhostbotai_chunks

# OpenAI
OPENAI_API_KEY=
OPENAI_ANSWER_MODEL=gpt-5-nano
OPENAI_FALLBACK_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_STORE=false

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Worker
WORKER_POLL_INTERVAL_MS=3000
CHUNK_SIZE=700
CHUNK_OVERLAP=120
MAX_CONTEXT_CHUNKS=4
