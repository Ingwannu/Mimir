{
  "name": "wickedhostbotai",
  "private": true,
  "packageManager": "pnpm@10.2.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test:stack": "tsx scripts/stack-smoke.ts",
    "test:pgvector": "tsx scripts/pgvector-e2e.ts",
    "dev:api": "pnpm --filter @wickedhostbotai/api dev",
    "dev:web": "pnpm --filter @wickedhostbotai/web dev",
    "dev:bot": "pnpm --filter @wickedhostbotai/bot dev",
    "dev:worker": "pnpm --filter @wickedhostbotai/worker dev",
    "db:migrate": "pnpm --filter @wickedhostbotai/db migrate"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
